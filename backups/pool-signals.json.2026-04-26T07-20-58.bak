[
  {"headline":"沙特阿美宣布将绿氢出口产能目标推迟至2035年","verdict":"signal","reason":"全球最大油气公司的战略节奏是行业晴雨表。推迟表明绿氢经济性问题仍未解决，给国内相关投资提供参照系。","key_metric":"电解槽成本是否跌破500美元/千瓦"},
  {"headline":"某网红氢燃料电池汽车公司宣布完成10亿元B轮融资","verdict":"noise","reason":"单次融资事件本身不能说明技术突破，资本热情往往领先实际进展2-3年。需看交付里程数和加氢站建设数。","key_metric":"可交付车辆数量和氢气零售价格"},
  {"headline":"欧盟通过《净零工业法案》，氢电解槽制造商可获快速审批","verdict":"signal","reason":"监管支持是技术规模化的必要条件之一。欧盟标准往往成为全球标杆，对中国电解槽出口意义重大。","key_metric":"欧洲电解槽本土制造容量增速"},
  {"headline":"国内某电解槽企业月度出货量再创历史新高","verdict":"signal","reason":"出货量是需求侧真实信号，比订单更可靠。持续新高说明市场正从政策驱动转向需求驱动。","key_metric":"连续6个月的同比增速趋势"},
  {"headline":"马斯克在社交媒体发文嘲讽氢燃料电池是\u201c蠢透的\u201d","verdict":"noise","reason":"马斯克有强烈的竞争利益，其言论更多是市场营销而非中立技术判断。忽略情绪，看底层数据。","key_metric":"氢燃料电池商用车的TCO与纯电动的差距"},
  {"headline":"全球最大光伏组件制造商宣布进军电解槽市场","verdict":"signal","reason":"光伏行业具有极强的降本经验和制造能力，其入场意味着电解槽成本曲线可能以意想不到的速度下降。","key_metric":"其量产产品的单瓦电解效率"},
  {"headline":"氢能概念股今日集体涨停","verdict":"noise","reason":"短期股价受市场情绪驱动，与技术或业务的实质进展关联极弱。概念炒作和真实行业进展完全可以背离。","key_metric":"行业龙头企业的毛利率变化"},
  {"headline":"IEA报告：2025年全球绿氢产量仅占预期目标的8%","verdict":"signal","reason":"国际能源署的系统性追踪数据，有基准线对比，是最可靠的信号之一。偏差巨大值得深究结构性原因。","key_metric":"电力成本在绿氢生产成本中的占比"},
  {"headline":"国内某城市公交系统完成从燃油到氢能全量替换","verdict":"signal","reason":"地方政府具体落地项目是政策信心的具体体现，也为其他城市提供可复制的范式。","key_metric":"每公里运营成本与柴油公交的对比"},
  {"headline":"AI大模型公司宣布用机器学习加速电解催化剂筛选","verdict":"signal","reason":"AI+材料的组合已有可复现的成果（DeepMind的GNoME等），有可能将催化剂开发周期从数年缩短至数月。","key_metric":"模型预测准确率和实验验证成功率"},
  {"headline":"日本松下宣布退出氢燃料电池车用催化剂市场","verdict":"signal","reason":"老牌巨头退出往往预示该细分市场的盈利模式出现问题，或技术路线出现重大分叉。","key_metric":"退出背后的成本结构原因"},
  {"headline":"某政府工作报告首次将绿氢列入能源安全战略","verdict":"signal","reason":"政策文件中的措辞升格是中国政策走向的重要信号，往往预示着预算和配套政策的跟进。","key_metric":"国家能源局后续招标文件中的绿氢比例要求"},
  {"headline":"全球碳价首次突破100欧元/吨大关","verdict":"signal","reason":"碳价是绿氢经济性的重要变量。碳价越高，绿氢对比灰氢的成本竞争力越强，是真实市场信号。","key_metric":"绿氢与灰氢的平准化成本差距"},
  {"headline":"国内某知名高校在顶刊发表最新电催化论文","verdict":"noise","reason":"单篇学术论文的样本空间极小，且从实验室到产业化有巨大鸿沟。除非是可量产的系统级突破，否则无需过度解读。","key_metric":"该研究是否有企业合作方和中试计划"},
  {"headline":"美国《通货膨胀削减法案》氢能税收抵免细则终于落地","verdict":"signal","reason":"政策执行细则直接影响项目IRR计算，是资本流向的开关。细则落地意味着美国绿氢项目开发商可以开始计算账本。","key_metric":"能满足条款的绿氢项目LCOH"},
  {"headline":"特斯拉宣布最新款电动皮卡续航突破800公里","verdict":"noise","reason":"电动汽车续航进步不影响氢能的核心优势场景（重载长距离、快速加注）。这是不同赛道的新闻。","key_metric":"商用重卡场景中氢和电的TCO对比"},
  {"headline":"中石化宣布在全国新建1000座加氢站","verdict":"signal","reason":"加注基础设施是氢能汽车推广的核心瓶颈。石化巨头的大规模投入具有强烈的规模化信号，且执行力强。","key_metric":"加氢站单站盈亏平衡的日加注量要求"},
  {"headline":"某咨询公司发布《2030年氢能市场规模将达万亿》报告","verdict":"noise","reason":"咨询公司的市场预测通常过于乐观（客户导向偏差），且大多数10年期预测准确率极低，可作为方向参考，不可作为决策依据。","key_metric":"预测假设中的电解槽成本和绿电价格"},
  {"headline":"全球最大风电运营商开始在海上平台直接制氢","verdict":"signal","reason":"将可再生能源和电解水制氢集成在同一系统中，绕过远距离输电损耗，是商业化绿氢的重要技术路线。","key_metric":"该系统的电解效率和氢气运输成本"},
  {"headline":"国内某省份出台绿氢补贴政策，每公斤补贴15元","verdict":"signal","reason":"地方政府的具体补贴数字是政策意愿的量化指标。15元/kg覆盖了大部分绿氢与灰氢的成本差距，信号强度较高。","key_metric":"补贴规模总额和执行年限"},
  {"headline":"某电解槽企业因质量问题被德国大客户退货","verdict":"signal","reason":"质量问题是中国制造业出海的核心考验。单次退货可能是偶然，但若形成批次问题，说明产品成熟度不足。","key_metric":"退货率和保质期内故障率"},
  {"headline":"世界银行预测全球氢能投资将在3年内翻倍","verdict":"noise","reason":"多边机构的预测偏保守但往往滞后反映已有趋势，翻倍预测是在描述已经发生的事，而非未来的机遇窗口。","key_metric":"当前实际资本配置中绿氢占比"},
  {"headline":"德国宣布将国家氢能战略中蓝氢比例上调","verdict":"signal","reason":"德国从绿氢主导向蓝氢开门，是现实主义的信号，意味着2030年目标将主要通过进口和过渡路径实现，对中国绿氢出口机遇有直接影响。","key_metric":"欧洲氢能进口渠道的格局变化"},
  {"headline":"某氢能创业公司完成A轮融资，估值50亿","verdict":"noise","reason":"一级市场估值受情绪和谈判影响大，与实际技术价值脱节。更重要的信号是：他们的产品有没有真实客户？","key_metric":"ARR（年度经常性收入）和签约客户数"},
  {"headline":"IRENA发布报告显示全球绿电平准化成本连续5年下降","verdict":"signal","reason":"绿电成本是绿氢成本的最大组成部分（约60-70%）。绿电持续降本是绿氢经济性改善的最强底层驱动力。","key_metric":"光伏+风电综合成本能否在2030年前跌破0.02美元/度"},
  {"headline":"国内某地方政府因财政压力叫停氢能补贴项目","verdict":"signal","reason":"政策可持续性风险是行业判断的重要维度。当政策退坡信号出现，需要重新评估依赖补贴的商业模式的竞争力。","key_metric":"行业内靠补贴存活的企业占比"},
  {"headline":"比尔·盖茨接受采访表示看好固态氢储能","verdict":"noise","reason":"名人背书是注意力事件，不是技术信号。比尔·盖茨同时投了数十个方向，不代表任何具体方向的技术可行性。","key_metric":"固态储氢系统的重量比容量和充放速率"},
  {"headline":"国家发展改革委发布可再生能源制氢项目审批流程简化通知","verdict":"signal","reason":"行政效率提升直接影响项目开发周期和IRR，是政策落地质量的重要指标。","key_metric":"审批时间缩短的具体数字"},
  {"headline":"某AI公司声称用强化学习将燃料电池寿命延长30%","verdict":"noise","reason":"声称需要独立第三方验证。AI在能源领域的性能声称存在大量虚假或过度宣传，实验室结果难以复现于真实工况。","key_metric":"是否有同行评审论文和第三方检测数据"},
  {"headline":"日本氢能供应链项目：澳大利亚棕煤制氢试验正式落地","verdict":"signal","reason":"真实项目落地意味着路线之争的阶段性答案。蓝氢/棕煤氢的规模化先行，为绿氢争取了时间窗口。","key_metric":"项目氢气到日本港口的综合成本"}
]
